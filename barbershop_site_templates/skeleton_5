      <div class="price-row"><span class="price-row__name">Beard Trim</span><span class="price-row__price">€15</span></div>
      <div class="price-row"><span class="price-row__name">The Works</span><span class="price-row__price">€55</span></div>
      <div class="price-row"><span class="price-row__desc">Cut, shave, beard trim & styling</span></div>
    </div>
  </div>
</section>

<div class="ornament">✦ ✦ ✦</div>

<section class="team" id="team">
  <div class="container">
    <h2 class="reveal">The Barbers</h2>
    <div class="team__grid reveal">
      <div class="polaroid"><div class="polaroid__photo"></div><h3>NAME</h3><p>Master Barber</p></div>
      <div class="polaroid"><div class="polaroid__photo"></div><h3>NAME</h3><p>Senior Barber</p></div>
      <div class="polaroid"><div class="polaroid__photo"></div><h3>NAME</h3><p>Apprentice</p></div>
