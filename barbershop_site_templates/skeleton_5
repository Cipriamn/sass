</section>

<footer class="footer">
  <div class="container">
    <div class="footer__brand">BRAND NAME</div>
    <p class="footer__tagline">Est. 1963 — Traditional Barbering</p>
    <ul class="footer__socials"><li><a href="#">Instagram</a></li><li><a href="#">Facebook</a></li></ul>
    <p>© 2026 Brand Name</p>
  </div>
</footer>

</body>
