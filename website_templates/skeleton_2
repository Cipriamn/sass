<div class="stats-bar">
  <div class="container">
    <div class="stats-bar__inner">
      <div class="stat"><div class="stat__number">15+</div><div class="stat__label">Years Experience</div></div>
      <div class="stat"><div class="stat__number">10k+</div><div class="stat__label">Happy Clients</div></div>
      <div class="stat"><div class="stat__number">5</div><div class="stat__label">Expert Barbers</div></div>
