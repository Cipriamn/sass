<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skeleton 02 — Split Hero Modern</title>
<style>
/*──────────────────────────────────────────────
  SKELETON 02: SPLIT HERO MODERN
  Best for: Modern salons, upscale grooming studios,
  businesses that want a clean editorial feel.
  
  Layout: Split 50/50 hero → floating stat bar → 
  offset about → tabbed services → team carousel-style → 
  compact hours pills → CTA banner → contact → footer
  
  Vibe: Clean, editorial, premium
  Font pairing suggestion: DM Serif Display + DM Sans
──────────────────────────────────────────────*/
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --primary: #0d1117;
  --primary-light: #1c2333;
  --highlight: #e8b931;
  --highlight-dark: #c99e20;
  --dark: #0d1117;
  --darker: #080b10;
  --light: #f6f7f9;
  --text: #2d3748;
  --text-light: #718096;
  --white: #fff;
  --space-xs:.5rem;--space-sm:1rem;--space-md:2rem;--space-lg:4rem;--space-xl:6rem;--space-2xl:8rem;
  --radius-sm:6px;--radius-md:12px;--radius-lg:20px;--radius-pill:999px;
  --shadow-sm:0 2px 8px rgba(0,0,0,0.06);--shadow-md:0 8px 30px rgba(0,0,0,0.1);--shadow-lg:0 20px 60px rgba(0,0,0,0.12);
  --font-display:'DM Serif Display',Georgia,serif;
  --font-body:'DM Sans',sans-serif;
}

body{font-family:var(--font-body);color:var(--text);line-height:1.6;background:var(--white)}
.container{max-width:1200px;margin:0 auto;padding:0 var(--space-md)}
section{padding:var(--space-xl) 0}
h1,h2,h3{font-family:var(--font-display);font-weight:400;line-height:1.2}

/* ─── HEADER ─── */
.header{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:var(--space-sm) 0;
  transition:all 0.4s;
}
.header.scrolled{background:rgba(255,255,255,0.92);backdrop-filter:blur(12px);box-shadow:var(--shadow-sm)}
.header .container{display:flex;justify-content:space-between;align-items:center}
.header__logo{font-family:var(--font-display);font-size:1.4rem;color:var(--primary);text-decoration:none}
.header__nav{display:flex;gap:var(--space-md);list-style:none}
.header__nav a{color:var(--text);text-decoration:none;font-size:0.85rem;letter-spacing:0.5px}
.header__cta{background:var(--primary);color:var(--white);padding:0.6rem 1.5rem;border-radius:var(--radius-pill);text-decoration:none;font-size:0.85rem}

/* ─── HERO: Split 50/50 ─── */
.hero{
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 1fr;
}
.hero__image{
  background:var(--dark);/* Replace with image */
  position:relative;overflow:hidden;
}
.hero__image::before{
  content:'';position:absolute;inset:0;
  background:var(--dark);
  animation:heroZoom 20s ease infinite alternate;
}
.hero__text{
  display:flex;flex-direction:column;justify-content:center;
  padding:var(--space-2xl) var(--space-xl);
}
.hero__label{
  color:var(--highlight);font-size:0.75rem;letter-spacing:3px;
  text-transform:uppercase;margin-bottom:var(--space-md);
}
.hero h1{font-size:clamp(2.5rem,5vw,4rem);margin-bottom:var(--space-sm)}
.hero__subtitle{color:var(--text-light);font-size:1.1rem;margin-bottom:var(--space-lg)}
.hero__buttons{display:flex;gap:var(--space-sm)}

.btn{display:inline-block;padding:0.85rem 2rem;border-radius:var(--radius-pill);font-size:0.9rem;font-weight:500;text-decoration:none;transition:all 0.3s}
.btn-main{background:var(--primary);color:var(--white);border:2px solid var(--primary)}
.btn-main:hover{background:var(--highlight);border-color:var(--highlight)}
.btn-ghost{background:transparent;color:var(--primary);border:2px solid rgba(0,0,0,0.15)}
.btn-ghost:hover{border-color:var(--primary)}

/* ─── STATS BAR: Floating over sections ─── */
.stats-bar{
  position:relative;z-index:10;
  margin-top:calc(var(--space-xl) * -1);
  margin-bottom:var(--space-lg);
}
.stats-bar__inner{
  background:var(--white);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-lg);
  display:grid;
  grid-template-columns:repeat(4,1fr);
  padding:var(--space-lg);
  text-align:center;
}
.stat__number{font-family:var(--font-display);font-size:2.5rem;color:var(--primary)}
.stat__label{font-size:0.8rem;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-top:var(--space-xs)}

/* ─── ABOUT: Offset image overlapping text ─── */
.about{position:relative}
.about__grid{
  display:grid;
  grid-template-columns:5fr 6fr;
  gap:var(--space-xl);
  align-items:center;
}
.about__image{
  aspect-ratio:3/4;
  background:var(--light);
  border-radius:var(--radius-md);
  position:relative;
}
.about__image::after{
  content:'';position:absolute;
  top:var(--space-md);left:var(--space-md);right:calc(var(--space-md) * -1);bottom:calc(var(--space-md) * -1);
  border:2px solid var(--highlight);border-radius:var(--radius-md);
  z-index:-1;
}
.about__text h2{font-size:clamp(2rem,4vw,3rem);margin-bottom:var(--space-md)}
.about__text p{color:var(--text-light);margin-bottom:var(--space-md);max-width:500px}

/* ─── SERVICES: Tabbed categories ─── */
.services{background:var(--light)}
.services h2{text-align:center;font-size:2.5rem;margin-bottom:var(--space-md)}
.services__tabs{
  display:flex;justify-content:center;gap:var(--space-sm);
  margin-bottom:var(--space-xl);
}
.services__tab{
  padding:0.6rem 1.5rem;border-radius:var(--radius-pill);
  background:transparent;border:1px solid rgba(0,0,0,0.15);
  cursor:pointer;font-size:0.85rem;transition:all 0.3s;
}
.services__tab.active,.services__tab:hover{background:var(--primary);color:var(--white);border-color:var(--primary)}
.services__list{
  max-width:700px;margin:0 auto;
}
.service-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:var(--space-md) 0;
  border-bottom:1px solid rgba(0,0,0,0.08);
}
.service-row__name{font-weight:500}
.service-row__dots{flex:1;border-bottom:2px dotted rgba(0,0,0,0.1);margin:0 var(--space-md);height:1px}
.service-row__price{font-family:var(--font-display);font-size:1.2rem;color:var(--highlight)}

/* ─── TEAM: Horizontal scroll cards ─── */
.team h2{text-align:center;font-size:2.5rem;margin-bottom:var(--space-xl)}
.team__scroll{
  display:flex;gap:var(--space-md);
  overflow-x:auto;
  padding-bottom:var(--space-md);
  scroll-snap-type:x mandatory;
}
.team-card{
  flex:0 0 300px;
  scroll-snap-align:start;
  border-radius:var(--radius-md);
  overflow:hidden;
  background:var(--white);
  box-shadow:var(--shadow-sm);
  transition:transform 0.3s,box-shadow 0.3s;
}
.team-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-md)}
.team-card__photo{aspect-ratio:3/4;background:var(--light)}
.team-card__info{padding:var(--space-md);text-align:center}
.team-card__info h3{margin-bottom:var(--space-xs)}
.team-card__role{color:var(--highlight);font-size:0.8rem;text-transform:uppercase;letter-spacing:1px}

/* ─── HOURS: Compact pills ─── */
.hours{background:var(--primary);color:var(--white);text-align:center}
.hours h2{font-size:2.5rem;margin-bottom:var(--space-lg)}
.hours__pills{
  display:flex;justify-content:center;gap:var(--space-sm);flex-wrap:wrap;
  max-width:800px;margin:0 auto;
}
.hours__pill{
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.1);
  padding:var(--space-sm) var(--space-md);
  border-radius:var(--radius-pill);
  font-size:0.9rem;
}
.hours__pill.today{background:var(--highlight);color:var(--primary);border-color:var(--highlight);font-weight:600}
.hours__pill span{opacity:0.6;margin-right:var(--space-xs)}

/* ─── CTA BANNER ─── */
.cta-banner{
  background:var(--highlight);
  text-align:center;
  padding:var(--space-xl) var(--space-md);
}
.cta-banner h2{font-size:clamp(2rem,4vw,3rem);color:var(--primary);margin-bottom:var(--space-md)}
.cta-banner .btn{background:var(--primary);color:var(--white);border-color:var(--primary)}

/* ─── CONTACT ─── */
.contact__grid{display:grid;grid-template-columns:1fr 1.5fr;gap:var(--space-xl)}
.contact__card h2{font-size:2rem;margin-bottom:var(--space-md)}
.contact__info{list-style:none;display:flex;flex-direction:column;gap:var(--space-md)}
.contact__info li{display:flex;gap:var(--space-sm);align-items:flex-start}
.contact__info strong{display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-light);margin-bottom:2px}
.contact__map{aspect-ratio:16/10;background:var(--light);border-radius:var(--radius-md)}

/* ─── FOOTER ─── */
.footer{background:var(--darker);color:rgba(255,255,255,0.5);padding:var(--space-lg) 0}
.footer .container{display:flex;justify-content:space-between;align-items:center}
.footer__brand{font-family:var(--font-display);color:var(--white);font-size:1.2rem}
.footer__links{display:flex;gap:var(--space-md);list-style:none}
.footer__links a{color:rgba(255,255,255,0.5);text-decoration:none;font-size:0.85rem}
.footer__links a:hover{color:var(--highlight)}

/* ─── ANIMATIONS ─── */
.reveal{opacity:0;transform:translateY(40px);transition:all 1s ease}
.reveal-left{opacity:0;transform:translateX(-50px);transition:all 1s ease}
.reveal-right{opacity:0;transform:translateX(50px);transition:all 1s ease}
.reveal.active,.reveal-left.active,.reveal-right.active{opacity:1;transform:translate(0)}
@keyframes heroZoom{from{transform:scale(1.05)}to{transform:scale(1.15)}}

@media(max-width:768px){
  .hero{grid-template-columns:1fr;min-height:auto}
  .hero__image{min-height:50vh}
  .hero__text{padding:var(--space-xl) var(--space-md)}
  .stats-bar__inner{grid-template-columns:repeat(2,1fr);gap:var(--space-md)}
  .about__grid,.contact__grid{grid-template-columns:1fr}
  .about__image::after{display:none}
  .footer .container{flex-direction:column;gap:var(--space-md);text-align:center}
  .footer__links{flex-wrap:wrap;justify-content:center}
}
</style>
</head>
<body>

<header class="header">
  <div class="container">
    <a href="#" class="header__logo">Brand Name</a>
    <nav><ul class="header__nav">
      <li><a href="#about">About</a></li>
