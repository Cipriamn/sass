<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skeleton 03 — Dark Luxury</title>
<style>
/*──────────────────────────────────────────────
  SKELETON 03: DARK LUXURY
  Best for: High-end barbershops, gentleman's clubs,
  premium grooming studios.
  
  Layout: Full dark bg throughout → hero with diagonal 
  clip → floating review bar → bento grid services → 
  full-bleed parallax break → team with overlay → 
  hours integrated into footer
  
  Vibe: Dark, luxurious, bold
  Font pairing suggestion: Cormorant Garamond + Outfit
──────────────────────────────────────────────*/
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --primary:#0a0a0a;
  --primary-light:#1a1a1a;
  --highlight:#c9a050;
  --highlight-dark:#a88335;
  --dark:#050505;
  --darker:#000;
  --light:#141414;
  --text:#e0ddd5;
  --text-light:#8a8780;
  --white:#f5f0e8;
  --space-xs:.5rem;--space-sm:1rem;--space-md:2rem;--space-lg:4rem;--space-xl:6rem;--space-2xl:8rem;
  --radius-sm:4px;--radius-md:8px;--radius-lg:16px;--radius-pill:999px;
  --shadow-glow:0 0 40px rgba(201,160,80,0.15);
  --font-display:'Cormorant Garamond',Georgia,serif;
  --font-body:'Outfit',sans-serif;
}

body{font-family:var(--font-body);color:var(--text);line-height:1.6;background:var(--primary)}
.container{max-width:1200px;margin:0 auto;padding:0 var(--space-md)}
section{padding:var(--space-xl) 0}
h1,h2,h3{font-family:var(--font-display);font-weight:400;line-height:1.15;color:var(--white)}
a{color:var(--highlight)}

/* ─── HEADER ─── */
.header{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:var(--space-sm) 0;
  transition:all 0.4s;
}
.header.scrolled{background:rgba(10,10,10,0.9);backdrop-filter:blur(16px)}
.header .container{display:flex;justify-content:space-between;align-items:center}
.header__logo{font-family:var(--font-display);font-size:1.6rem;color:var(--white);text-decoration:none;letter-spacing:2px}
.header__nav{display:flex;gap:var(--space-md);list-style:none}
.header__nav a{color:var(--text-light);text-decoration:none;font-size:0.8rem;letter-spacing:1.5px;text-transform:uppercase;transition:color 0.3s}
.header__nav a:hover{color:var(--highlight)}

/* ─── HERO: Diagonal clip ─── */
.hero{
  min-height:100vh;
  display:flex;align-items:center;
  position:relative;overflow:hidden;
  clip-path:polygon(0 0,100% 0,100% 92%,0 100%);
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:var(--dark);/* Replace with image */
  animation:heroZoom 20s ease infinite alternate;
}
.hero::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(0,0,0,0.8) 40%,rgba(201,160,80,0.1));
}
.hero__content{position:relative;z-index:2;padding:var(--space-2xl) 0}
.hero__eyebrow{
  color:var(--highlight);font-family:var(--font-display);font-style:italic;
  font-size:1.2rem;margin-bottom:var(--space-sm);
}
.hero h1{
  font-size:clamp(3rem,8vw,6rem);
  font-weight:300;letter-spacing:-1px;
  margin-bottom:var(--space-md);
}
.hero h1 em{font-style:italic;color:var(--highlight)}
.hero__line{width:60px;height:2px;background:var(--highlight);margin-bottom:var(--space-md)}
.hero__subtitle{font-size:1rem;color:var(--text-light);max-width:450px;margin-bottom:var(--space-lg)}

.btn{display:inline-flex;align-items:center;gap:var(--space-xs);padding:1rem 2.2rem;font-size:0.8rem;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:all 0.3s}
.btn-gold{background:var(--highlight);color:var(--primary);border:none}
.btn-gold:hover{background:var(--white);box-shadow:var(--shadow-glow)}
.btn-line{color:var(--white);border-bottom:1px solid var(--text-light);padding:0.5rem 0}
.btn-line:hover{border-color:var(--highlight);color:var(--highlight)}

/* ─── REVIEW BAR ─── */
.review-bar{
  padding:var(--space-lg) 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
}
.review-bar__inner{
  display:flex;align-items:center;justify-content:center;
  gap:var(--space-xl);flex-wrap:wrap;
  text-align:center;
}
.review-bar__stars{color:var(--highlight);font-size:1.2rem;letter-spacing:2px}
.review-bar__text{color:var(--text-light);font-size:0.9rem}
.review-bar__text strong{color:var(--white)}
.review-bar__badges{display:flex;gap:var(--space-md)}
.review-bar__badge{
  padding:var(--space-xs) var(--space-sm);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:var(--radius-sm);
  font-size:0.75rem;color:var(--text-light);
}

/* ─── ABOUT ─── */
.about__grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-2xl);align-items:center}
.about__image{aspect-ratio:4/5;background:var(--light);border-radius:var(--radius-sm)}
.about h2{font-size:clamp(2rem,4vw,3.5rem);font-weight:300;margin-bottom:var(--space-md)}
.about p{color:var(--text-light);margin-bottom:var(--space-md)}

/* ─── SERVICES: Bento grid ─── */
.services h2{font-size:3rem;font-weight:300;margin-bottom:var(--space-xl);text-align:center}
.bento{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-auto-rows:200px;
  gap:var(--space-sm);
}
.bento__item{
  background:var(--light);
  border:1px solid rgba(255,255,255,0.04);
  border-radius:var(--radius-md);
  padding:var(--space-md);
  display:flex;flex-direction:column;justify-content:flex-end;
  position:relative;overflow:hidden;
  transition:border-color 0.3s,transform 0.3s;
}
.bento__item:hover{border-color:rgba(201,160,80,0.3);transform:translateY(-4px)}
.bento__item--tall{grid-row:span 2}
.bento__item--wide{grid-column:span 2}
.bento__item h3{font-size:1.3rem;margin-bottom:var(--space-xs)}
.bento__item p{font-size:0.85rem;color:var(--text-light)}
.bento__price{
  position:absolute;top:var(--space-md);right:var(--space-md);
  font-family:var(--font-display);font-size:1.5rem;color:var(--highlight);
}

/* ─── PARALLAX BREAK ─── */
.parallax-break{
  min-height:50vh;
  background:var(--dark);/* Replace with fixed bg image */
  background-attachment:fixed;
  display:flex;align-items:center;justify-content:center;
  text-align:center;
  position:relative;
}
.parallax-break::after{content:'';position:absolute;inset:0;background:rgba(0,0,0,0.6)}
.parallax-break__content{position:relative;z-index:2}
.parallax-break blockquote{
  font-family:var(--font-display);font-style:italic;
  font-size:clamp(1.5rem,3vw,2.5rem);color:var(--white);
  max-width:600px;
}
.parallax-break cite{display:block;margin-top:var(--space-sm);font-size:0.85rem;color:var(--highlight);font-style:normal}

/* ─── TEAM: Cards with overlay ─── */
.team h2{font-size:3rem;font-weight:300;text-align:center;margin-bottom:var(--space-xl)}
.team__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-sm)}
.team-card{
  aspect-ratio:3/4;
  background:var(--light);
  border-radius:var(--radius-md);
  position:relative;overflow:hidden;
  cursor:pointer;
}
.team-card__overlay{
  position:absolute;bottom:0;left:0;right:0;
  padding:var(--space-md);
  background:linear-gradient(transparent,rgba(0,0,0,0.9));
  transform:translateY(30%);
  transition:transform 0.4s;
}
.team-card:hover .team-card__overlay{transform:translateY(0)}
.team-card__overlay h3{margin-bottom:var(--space-xs)}
.team-card__overlay p{font-size:0.8rem;color:var(--highlight);text-transform:uppercase;letter-spacing:1px}

/* ─── HOURS + CONTACT: Combined dark block ─── */
.hours-contact{
  background:var(--dark);
  border-top:1px solid rgba(255,255,255,0.04);
}
.hours-contact__grid{display:grid;grid-template-columns:1fr 1px 1fr;gap:var(--space-xl);align-items:start}
.hours-contact__divider{background:rgba(255,255,255,0.06);height:100%}
.hours-contact h2{font-size:2rem;font-weight:300;margin-bottom:var(--space-lg)}
.hours__table{width:100%;border-collapse:collapse}
.hours__table tr{border-bottom:1px solid rgba(255,255,255,0.04)}
.hours__table td{padding:var(--space-sm) 0;font-size:0.9rem}
.hours__table td:first-child{color:var(--text-light)}
.hours__table td:last-child{text-align:right;color:var(--highlight)}
.hours__table tr.today td{color:var(--highlight);font-weight:600}
.contact__info{list-style:none;display:flex;flex-direction:column;gap:var(--space-md)}
.contact__info li strong{display:block;color:var(--text-light);font-size:0.7rem;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}
.contact__info li span{color:var(--white);font-size:1rem}

/* ─── MAP: Full width ─── */
.map-full{height:400px;background:var(--light)}

/* ─── FOOTER ─── */
.footer{
  background:var(--darker);padding:var(--space-lg) 0;
  text-align:center;color:var(--text-light);font-size:0.85rem;
}
.footer__brand{
  font-family:var(--font-display);font-size:2rem;color:var(--white);
  letter-spacing:3px;margin-bottom:var(--space-sm);
}
.footer__socials{display:flex;justify-content:center;gap:var(--space-md);margin-bottom:var(--space-md);list-style:none}
.footer__socials a{color:var(--text-light);text-decoration:none;transition:color 0.3s}
.footer__socials a:hover{color:var(--highlight)}

/* ─── ANIMATIONS ─── */
.reveal{opacity:0;transform:translateY(40px);transition:all 1s ease}
.reveal-left{opacity:0;transform:translateX(-50px);transition:all 1s ease}
.reveal-right{opacity:0;transform:translateX(50px);transition:all 1s ease}
.reveal.active,.reveal-left.active,.reveal-right.active{opacity:1;transform:translate(0)}
@keyframes heroZoom{from{transform:scale(1.05)}to{transform:scale(1.15)}}

@media(max-width:768px){
  .hero{clip-path:polygon(0 0,100% 0,100% 96%,0 100%)}
  .about__grid,.hours-contact__grid{grid-template-columns:1fr}
  .hours-contact__divider{display:none}
  .bento{grid-template-columns:1fr;grid-auto-rows:auto}
  .bento__item--tall,.bento__item--wide{grid-row:auto;grid-column:auto}
}
</style>
</head>
<body>

<header class="header">
  <div class="container">
    <a href="#" class="header__logo">BRAND</a>
